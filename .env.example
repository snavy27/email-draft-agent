# Copy this file to .env and fill in both secrets. The agent runs fully headless: the API key
# authenticates the model, and the Notion integration token authenticates the CRM via our own
# read-only Notion MCP server. There is no claude.ai login fallback for either.

# Anthropic API key for model auth (https://console.anthropic.com/).
ANTHROPIC_API_KEY=

# Notion internal integration token (https://www.notion.so/my-integrations). The integration
# must be shared with the Accounts, Meetings, and Contacts databases (••• → Connections).
NOTION_TOKEN=

# Google Calendar (only for the live `--calendar` CLI; the evals mock the calendar).
# Service-account JSON path + the calendar id (your address) shared read-only with that account.
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
GOOGLE_CALENDAR_ID=

# Email delivery (scheduled_run.py) — the ONLY outbound action. Gmail SMTP with an App Password is
# recommended: enable 2-Step Verification, then create an App Password and paste the 16 chars here
# (a normal account password will not work). Credentials are never logged or printed.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
# Sender shown on the email (defaults to SMTP_USER if blank) and the single recipient.
# BRIEF_RECIPIENT must be ONE address (no comma-separated lists).
BRIEF_FROM=you@gmail.com
BRIEF_RECIPIENT=shardanavalika@gmail.com

# Dead-man's switch (optional). On a fully successful run the job pings this URL after the email
# sends. Point a healthchecks.io-style monitor at it, set to expect a daily ping shortly after the
# scheduled send time — a no-show (host down, cron broken, laptop asleep) then alerts you.
HEARTBEAT_URL=

# Tuning knobs (all optional; sensible defaults shown):
# WEB_RECENCY_DAYS=183       # drop web news older than this many days (recency grounding)
# BRIEF_MEETING_TIMEOUT=300  # per-meeting budget (s); a hung meeting is failed, not the whole run
# CAL_TIMEOUT=60             # Google Calendar read timeout (s); a hang → whole-run failure email
# NOTION_TIMEOUT=30          # per Notion API request timeout (s)
